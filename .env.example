# TriadRank ATS — runtime config for docker-compose.
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# HuggingFace read-scope token with access to your private checkpoint repos.
# Create at https://huggingface.co/settings/tokens (read scope is enough).
# Rotate immediately if leaked (chat transcripts included).
HF_TOKEN=

# Private HF repo ids where your trained checkpoints live.
# Each repo must contain a file named `best_model.pt` at its root.
CHECKPOINT_REPO_CROSS=Akuma1da/cross-encoder
CHECKPOINT_REPO_CATEGORY=Akuma1da/category-encoder

# Inference device: cpu | cuda | auto. api/main.py honors this (overrides config.yaml).
MODEL_DEVICE=cpu

# Uvicorn worker count. Each worker loads its own copy of the models in RAM, so
# keep 1 on CPU unless you have memory to spare and need concurrency.
UVICORN_WORKERS=1

# Dev/offline only. Set to 1 to allow random UNTRAINED weights when checkpoints
# can't be loaded. The API then reports degraded (/health -> 503). Leave unset for prod.
# ALLOW_RANDOM_FALLBACK=1
